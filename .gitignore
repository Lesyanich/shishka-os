# MemPalace — venv is local-only, never committed (spec §3.1).
# Only requirements.txt, scripts, README, blocklist, and public key are tracked.
services/mempalace/.venv/
# Guard against accidental commit of live data if ~/.mempalace/ is copied into the repo by mistake.
services/mempalace/palace/
services/mempalace/knowledge_graph.sqlite3
services/mempalace/*.age
services/mempalace/*-key.txt

# MemPalace encrypted backups — binary blobs, recoverable from live data, not source
_backups/mempalace/

# Git worktrees for parallel manual sessions
.worktrees/
