# Supabase (public — ships in browser bundle, RLS is the protection layer)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# LightRAG (Brain View)
# Default points at the local Phase 1 server. Override for staging/prod.
VITE_LIGHTRAG_BASE_URL=http://localhost:9621
# Optional. Empty for local dev — server runs without auth.
VITE_LIGHTRAG_API_KEY=
