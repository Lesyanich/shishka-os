#!/bin/sh

# ============================================================
# Shishka OS — Post-commit: Reactive Status (HC-1)
# Spec: docs/plans/spec-ai-native-ops.md
#
# HC-1: STATUS.md is auto-generated on commit.
# Manual editing of STATUS.md is PROHIBITED.
# Runs async (background) so it doesn't block git workflow.
# ============================================================

echo "[post-commit] Commit: $(git log --oneline -1)"

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

# ── HC-1: STATUS.md auto-generation (non-blocking) ──
if [ -n "$REPO_ROOT" ] && [ -f "$REPO_ROOT/scripts/generate-status.sh" ]; then
  sh "$REPO_ROOT/scripts/generate-status.sh" &
fi

# ── Brain: detect changed files in this commit ──
CHANGED_FILES=""
if [ -n "$REPO_ROOT" ]; then
  CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)
fi

# ── Brain: LightRAG auto-reindex on bible/domain change ──
if [ -n "$CHANGED_FILES" ]; then
  BIBLE_DOMAIN=$(echo "$CHANGED_FILES" | grep -E '^docs/(bible|domain)/.*\.md$' || true)
  if [ -n "$BIBLE_DOMAIN" ]; then
    echo "[post-commit] Brain: LightRAG reindex triggered"
    echo "$BIBLE_DOMAIN" | sh "$REPO_ROOT/scripts/lightrag-reindex-changed.sh" &
  fi
fi

# ── Brain: MemPalace session-log auto-ingest ──
if [ -n "$CHANGED_FILES" ]; then
  SESSION_LOGS=$(echo "$CHANGED_FILES" | grep -E '^agents/.*/session-log\.md$' || true)
  if [ -n "$SESSION_LOGS" ]; then
    echo "[post-commit] Brain: MemPalace session-log ingest triggered"
    sh "$REPO_ROOT/scripts/mempalace-ingest-session.sh" &
  fi
fi
